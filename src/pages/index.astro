---
import Layout from "../layouts/Layout.astro";
import ExternalIcon from "../components/ExternalIcon.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => {
    const sa = a.data.stars ?? -1;
    const sb = b.data.stars ?? -1;
    if (sb !== sa) return sb - sa;
    return a.data.title.localeCompare(b.data.title);
});

const links = [
    { label: "github", href: "https://github.com/vasie1337" },
    { label: "x", href: "https://x.com/vasie1337" },
    { label: "linkedin", href: "https://www.linkedin.com/in/vascosmith/" },
    { label: "email", href: "mailto:vasie1337@gmail.com" },
];
---

<Layout
    title="Vasco Smith"
    description="systems, rust, windows internals. the netherlands."
>
    <main class="mx-auto px-6 py-24" style="max-width: var(--measure);">
        <header>
            <h1
                class="font-mono font-medium"
                style="font-size: var(--step-1); letter-spacing: -0.02em;"
            >
                Vasco Smith
            </h1>
            <p
                class="font-mono text-muted mt-2"
                style="font-size: var(--step--1);"
            >
                <span class="text-fg">vasie1337</span>
                <span class="mx-2 opacity-60">·</span>
                systems, rust, windows internals
                <span class="mx-2 opacity-60">·</span>
                the netherlands
            </p>
            <nav
                class="font-mono mt-6 flex gap-5 flex-wrap text-muted"
                style="font-size: var(--step--1);"
            >
                {
                    links.map((l) => (
                        <a href={l.href} rel="me noopener" class="no-underline hover:text-accent">
                            {l.label}
                        </a>
                    ))
                }
            </nav>
        </header>

        <section class="mt-20">
            <h2
                class="font-mono text-muted uppercase"
                style="font-size: var(--step--1); letter-spacing: 0.08em;"
            >
                projects
            </h2>
            <ul class="mt-6 flex flex-col gap-8">
                {
                    projects.map((p) => (
                        <li class="group">
                            <div class="flex items-baseline gap-3 flex-wrap">
                                <a
                                    href={p.data.url ?? "#"}
                                    rel="noopener"
                                    class="font-mono font-medium no-underline group-hover:text-accent"
                                    style="font-size: var(--step-0);"
                                >
                                    {p.data.title}
                                    <ExternalIcon class="ml-1 text-muted opacity-70 group-hover:opacity-100" />
                                </a>
                                {typeof p.data.stars === "number" && (
                                    <span
                                        class="font-mono text-muted"
                                        style="font-size: var(--step--1);"
                                    >
                                        ★ {p.data.stars}
                                    </span>
                                )}
                            </div>
                            <p class="mt-1.5 text-muted" style="font-size: var(--step--1);">
                                {p.data.description}
                            </p>
                            {p.data.tags.length > 0 && (
                                <div
                                    class="font-mono text-muted mt-2 flex gap-4 flex-wrap"
                                    style="font-size: var(--step--1);"
                                >
                                    {p.data.tags.map((t) => (
                                        <span>{t}</span>
                                    ))}
                                </div>
                            )}
                        </li>
                    ))
                }
            </ul>
        </section>

        <footer
            class="mt-24 pt-6 border-t font-mono text-muted"
            style="font-size: var(--step--1); border-color: var(--rule);"
        >
            <a href="https://developers.cloudflare.com/workers/" rel="noopener"
                >deployed on cloudflare workers</a
            >
        </footer>
    </main>
</Layout>
